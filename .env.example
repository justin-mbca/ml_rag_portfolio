# GenAI Financial Assistant – Environment Configuration
# Copy this file to .env and fill in your values

# OpenAI API
OPENAI_API_KEY=your-openai-api-key-here

# Neo4j
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password

# ChromaDB
CHROMA_HOST=localhost
CHROMA_PORT=8005

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=genai_financial
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# AWS (optional, for S3 document storage)
AWS_REGION=us-east-1
S3_BUCKET=

# Embedding model
EMBEDDING_MODEL=text-embedding-3-small

# Pipeline settings
CHUNK_SIZE=512
CHUNK_OVERLAP=64

# Model directories
MODEL_DIR=/models
